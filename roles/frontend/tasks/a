- name: install nginx
  ansible.builtin.package:
    name: nginx
    state: present

- name: remove default config (important)
  ansible.builtin.file:
    path: /etc/nginx/default.d
    state: absent

- name: recreate default config directory
  ansible.builtin.file:
    path: /etc/nginx/default.d
    state: directory

- name: copy reverse proxy config
  ansible.builtin.copy:
    src: expense.conf
    dest: /etc/nginx/default.d/expense.conf

- name: test nginx config
  ansible.builtin.command: nginx -t
  register: nginx_test
  failed_when: nginx_test.rc != 0

- name: start nginx
  ansible.builtin.service:
    name: nginx
    state: started
    enabled: true